# Local testing without Docker
# Usage: cp .env.local .env && python -m uvicorn app.main:app --port 8000

# Qdrant in-memory (no server needed)
QDRANT_MODE=memory
QDRANT_COLLECTION=documents

# LLM — GLM-4 via OpenAI-compatible API
LLM_PROVIDER=openai
LLM_MODEL=glm-4-flash
LLM_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.z.ai/api/coding/paas/v4  # or https://api.openai.com/v1

# Embeddings — local sentence-transformers (no API needed, runs on CPU)
EMBED_PROVIDER=sentence-transformers
EMBED_MODEL=all-MiniLM-L6-v2
EMBED_DIM=384

# Retrieval
RETRIEVAL_MODE=hybrid
TOP_K=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Cache
QUERY_CACHE_ENABLED=true
