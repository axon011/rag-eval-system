# ============================================================
# RAG Eval System — environment template
# Copy to .env for local dev, or mirror these keys into your
# Azure Container Apps / App Service config for production.
# ============================================================

# ─── LLM (any OpenAI-compatible provider) ──────────────────
# Supported: openai, anthropic, ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=your-api-key-here
# Point this at Azure OpenAI, GLM, or the real OpenAI endpoint:
OPENAI_BASE_URL=https://api.openai.com/v1

# ─── Embeddings ────────────────────────────────────────────
# Use 'sentence-transformers' for self-contained deploys (no API cost,
# model pre-downloaded in the Docker image). Use 'openai' for Azure OpenAI
# embeddings, or 'ollama' for local dev.
EMBED_PROVIDER=sentence-transformers
EMBED_MODEL=all-MiniLM-L6-v2

# ─── Qdrant ────────────────────────────────────────────────
# QDRANT_MODE=memory -> in-process, no external service (perfect for demos
# and single-container Azure deploys). Data is lost on restart.
# QDRANT_MODE=server -> talk to a real Qdrant instance (production).
QDRANT_MODE=memory
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=documents

# ─── Ollama (only if LLM_PROVIDER=ollama or EMBED_PROVIDER=ollama) ──
OLLAMA_BASE_URL=http://localhost:11434

# ─── MLflow tracking ───────────────────────────────────────
# For Azure: point at an MLflow server or use a mounted Azure File Share.
MLFLOW_TRACKING_URI=file:///app/mlruns

# ─── Retrieval ─────────────────────────────────────────────
RETRIEVAL_MODE=hybrid
TOP_K=5
CHUNK_SIZE=1200
CHUNK_OVERLAP=150

# ─── Cache ─────────────────────────────────────────────────
QUERY_CACHE_ENABLED=true
RESPONSE_CACHE_TTL=900
CACHE_MAX_SIZE=1000

# ─── API ───────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ─── CORS ──────────────────────────────────────────────────
# Comma-separated origins. Use "*" for open access. If you set real
# origins, you may also flip CORS_ALLOW_CREDENTIALS=true.
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false
